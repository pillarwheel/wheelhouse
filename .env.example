# WheelHouse environment configuration
# ------------------------------------
# Copy this file to ".env" (in the repo root or next to the executable) and fill in
# your values. WheelHouse loads ".env" on startup. Real OS environment variables
# always take precedence over values set here, and ".env" is git-ignored so your
# secrets are never committed.

# --- Anthropic (required to actually run Claude through Headroom) ---------------
# Headroom routes Claude through a local proxy by setting ANTHROPIC_BASE_URL, which
# disables Claude's subscription/OAuth login. An API key is therefore required for
# the proxy to authenticate; without it you'll get "401 authentication_failed".
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Gemini (planning, research, troubleshooting, cloud embedding fallback) -----
# Optional: the local ONNX embedding model works without this. Only Gemini-backed
# planning/troubleshooting and the cloud embedding fallback need a key.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Headroom token compression (optional) -------------------------------------
# auto = use Headroom when installed (default) | on = require it | off = never
WHEELHOUSE_HEADROOM=auto
# Explicit path to the headroom executable. Leave blank to auto-detect on PATH /
# common Python Scripts folders.
WHEELHOUSE_HEADROOM_PATH=

# Headroom auth: Headroom routes Claude through its proxy, which needs a valid Claude
# *subscription login* (run `claude login`). A bare ANTHROPIC_API_KEY is sent as a Bearer
# token and rejected by Anthropic; WheelHouse hides ANTHROPIC_API_KEY from the wrapped
# Claude so it uses your subscription login automatically.

# Optional — aggressive compression ("agent-90" profile, ~90% token-reduction target).
# Uncomment to push savings harder (inherited by the Headroom proxy WheelHouse starts):
# HEADROOM_MODE=token
# HEADROOM_SAVINGS_TARGET=0.90
# HEADROOM_TARGET_RATIO=0.10
# HEADROOM_COMPRESS_USER_MESSAGES=1
# HEADROOM_COMPRESS_SYSTEM_MESSAGES=1
# HEADROOM_FORCE_KOMPRESS=1

# --- RAG index file watching -----------------------------------------------------
# auto = watch workspace roots and re-index changed files automatically (default)
# off  = only re-index when triggered manually or on workspace add
WHEELHOUSE_WATCH=auto

# --- MCP tools for Claude ----------------------------------------------------------
# auto = serve search_code / get_knowledge to the Claude subprocess over MCP (default)
# off  = launch Claude without WheelHouse MCP tools
WHEELHOUSE_MCP=auto

# --- Gemini context caching ---------------------------------------------------------
# auto = cache large repository contexts server-side across plan/fix calls (default)
# off  = always resend the full context inline
WHEELHOUSE_GEMINI_CACHE=auto
