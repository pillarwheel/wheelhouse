# Normalize line endings to LF in the repo and on checkout (cross-platform consistency).
* text=auto eol=lf

# Windows-specific scripts keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat these as binary (never normalize / diff as text).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.onnx binary
*.dll  binary
*.exe  binary
*.so   binary
*.dylib binary
*.db   binary
