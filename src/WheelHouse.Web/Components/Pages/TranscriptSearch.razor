@page "/transcript-search"
@using Microsoft.Extensions.DependencyInjection
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Nav

<PageTitle>WheelHouse — Transcript Search</PageTitle>

<header class="page-head">
    <div>
        <h1>Transcript Search</h1>
        <p class="muted">Full-text search across every saved session transcript.</p>
    </div>
</header>

<section class="panel">
    <div class="row">
        <input class="input grow" placeholder="Search transcripts (e.g. error, dotnet test, Headroom)…"
               @bind="_query" @bind:event="oninput" @onkeyup="OnKey" />
        <button class="btn primary" @onclick="RunSearch" disabled="@_busy">
            @(_busy ? "Searching…" : "Search")
        </button>
    </div>

    @if (_status is not null)
    {
        <div class="alert subtle">@_status</div>
    }

    <ul class="card-list results">
        @foreach (var s in _results)
        {
            <li class="card clickable" @onclick="() => Open(s.SessionId)">
                <div class="card-main">
                    <div class="card-title">@s.SessionName</div>
                    <div class="card-sub mono">@s.RepositoryPath</div>
                    <div class="card-meta">
                        <span class="status status-@s.Status.ToString().ToLower()">@s.Status</span>
                        <span class="tag subtle">@s.MatchCount match@(s.MatchCount == 1 ? "" : "es")</span>
                    </div>
                    <div class="hits">
                        @foreach (var h in s.Hits)
                        {
                            <div class="hit">
                                <span class="hit-kind">@KindLabel(h.Kind)</span>
                                <span class="hit-text">
                                    @foreach (var seg in Segments(h.Snippet, _lastQuery))
                                    {
                                        @if (seg.Hit)
                                        {
                                            <mark>@seg.Text</mark>
                                        }
                                        else
                                        {
                                            @seg.Text
                                        }
                                    }
                                </span>
                            </div>
                        }
                    </div>
                </div>
                <span class="chevron">›</span>
            </li>
        }
    </ul>
</section>

@code {
    private string _query = "";
    private string _lastQuery = "";
    private bool _busy;
    private string? _status;
    private IReadOnlyList<TranscriptSessionMatches> _results = Array.Empty<TranscriptSessionMatches>();

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RunSearch();
    }

    private async Task RunSearch()
    {
        var q = _query.Trim();
        if (q.Length == 0 || _busy) return;
        _busy = true;
        _status = null;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var search = scope.ServiceProvider.GetRequiredService<ITranscriptSearch>();
            _results = await search.SearchAsync(q);
            _lastQuery = q;
            _status = _results.Count == 0
                ? $"No transcripts contain \"{q}\"."
                : $"{_results.Count} session{(_results.Count == 1 ? "" : "s")} matched.";
        }
        catch (Exception ex)
        {
            _status = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Open(int id) => Nav.NavigateTo($"/session/{id}");

    private static string KindLabel(string kind) => kind switch
    {
        "AssistantText" => "claude",
        "ToolUse" => "tool",
        "ToolResult" => "result",
        "System" => "sys",
        "Result" => "done",
        "Error" => "error",
        _ => "·"
    };

    private static IEnumerable<(string Text, bool Hit)> Segments(string text, string query)
    {
        if (string.IsNullOrEmpty(query) || string.IsNullOrEmpty(text))
        {
            yield return (text, false);
            yield break;
        }

        var i = 0;
        while (i < text.Length)
        {
            var idx = text.IndexOf(query, i, StringComparison.OrdinalIgnoreCase);
            if (idx < 0)
            {
                yield return (text[i..], false);
                break;
            }
            if (idx > i) yield return (text[i..idx], false);
            yield return (text.Substring(idx, query.Length), true);
            i = idx + query.Length;
        }
    }
}
