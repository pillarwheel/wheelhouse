@page "/session/{Id:int}"
@using Microsoft.Extensions.DependencyInjection
@using WheelHouse.Core.Search
@using WheelHouse.Core.Models.Script
@inject IDbContextFactory<WheelHouseDbContext> DbFactory
@inject ISessionFlowResolver FlowResolver
@inject IScriptExecutor ScriptExecutor
@inject IGitService Git
@inject IServiceScopeFactory ScopeFactory
@inject IJSRuntime JS
@inject IWorkspaceStateSyncService StateSync
@implements IDisposable

<PageTitle>WheelHouse — Session</PageTitle>

@if (_session is null)
{
    <div class="empty-state"><h1>Session not found</h1><a href="/">Back to dashboard</a></div>
}
else
{
    <header class="page-head">
        <div>
            @if (_editingName)
            {
                <div class="rename-row">
                    <input class="input rename-input" @bind="_nameDraft" @onkeydown="OnRenameKey" />
                    <button class="btn primary" @onclick="SaveName"
                            disabled="@string.IsNullOrWhiteSpace(_nameDraft)">Save</button>
                    <button class="btn ghost" @onclick="() => _editingName = false">Cancel</button>
                </div>
            }
            else
            {
                <div class="title-row">
                    <h1>@_session.Name</h1>
                    <button class="btn ghost icon-btn" title="Rename" @onclick="StartRename">✎</button>
                </div>
            }
            <p class="muted mono">@_session.RepositoryPath</p>
        </div>
        <div class="head-actions">
            @if (_templates.Count > 0)
            {
                <select class="input flow-select" title="Flow template — which planning/execution services this session uses"
                        value="@(_session.TemplateId?.ToString() ?? "")" @onchange="OnTemplateChanged">
                    @if (_session.TemplateId is null)
                    {
                        <option value="" disabled selected>Flow: default</option>
                    }
                    @foreach (var t in _templates)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            }
            <span class="status status-@_session.Status.ToString().ToLower()">@_session.Status</span>
            @if (_savedPath is not null)
            {
                <span class="tag" title="@_savedPath">saved to @SessionArchive.RelativePath(_session.Id)</span>
            }
            <button class="btn ghost" @onclick="SaveToWorkspace">Save to workspace</button>
            <button class="btn ghost" @onclick="ExportMarkdown">Export MD</button>
        </div>
    </header>

    @if (HasGraph)
    {
        <section class="panel graph-panel">
            <div class="panel-head">
                <h2>Visual Script · @(_session.Template?.Name)</h2>
                <button class="btn primary" @onclick="RunGraph" disabled="@_running">
                    @(_running ? "Running…" : "Run graph")
                </button>
            </div>
            <ScriptGraphView GraphJson="@(_session.Template?.GraphJson)" ActiveNodeId="@_activeNodeId" />

            @if (_metrics is { } m)
            {
                <div class="kpi-strip">
                    <span class="kpi" title="Nodes that ran without an engine error">
                        <span class="kpi-label">Node success</span>
                        <span class="kpi-val @(m.NodeSuccessRate >= 0.95 ? "ok" : "warn")">
                            @m.NodesSucceeded/@m.NodesExecuted (@($"{m.NodeSuccessRate:P0}"))
                        </span>
                    </span>
                    <span class="kpi" title="Final dotnet build/test result">
                        <span class="kpi-label">Compile</span>
                        <span class="kpi-val @(m.FinalVerificationPassed == false ? "warn" : "ok")">
                            @(m.FinalVerificationPassed is null ? "—" : m.FinalVerificationPassed.Value ? "pass" : "fail")
                        </span>
                    </span>
                    <span class="kpi" title="Wired inputs that resolved to an empty/missing value">
                        <span class="kpi-label">Handoff errors</span>
                        <span class="kpi-val @(m.HandoffErrors == 0 ? "ok" : "warn")">@m.HandoffErrors</span>
                    </span>
                    <span class="kpi" title="Approximate tokens across LLM/agent nodes (chars ÷ 4)">
                        <span class="kpi-label">~Tokens</span>
                        <span class="kpi-val @(m.ApproxTokens < 100_000 ? "ok" : "warn")">@m.ApproxTokens.ToString("N0")</span>
                    </span>
                    <span class="kpi" title="Wall-clock run time">
                        <span class="kpi-label">Duration</span>
                        <span class="kpi-val">@($"{m.ElapsedMs / 1000.0:0.0}s")</span>
                    </span>
                </div>
            }

            @if (_pendingApproval is not null)
            {
                <div class="trouble approval">
                    <div class="trouble-head">⏸ Approval required</div>
                    <pre class="fix-text">@_pendingApproval</pre>
                    <div class="row">
                        <button class="btn primary" @onclick="() => ResolveApproval(true)">Approve</button>
                        <button class="btn warn" @onclick="() => ResolveApproval(false)">Reject</button>
                    </div>
                </div>
            }
        </section>
    }
    else
    {
        <section class="pipeline">
            @foreach (var stage in PipelineStages())
            {
                <div class="pipe-node state-@stage.State.ToString().ToLower()">
                    <div class="pipe-dot">@(stage.State == StageState.Done ? "✓" : "")</div>
                    <div class="pipe-label">@stage.Label</div>
                    <div class="pipe-sub">@stage.Sub</div>
                </div>
            }
        </section>
    }

    <section class="split">
        <div class="panel plan-panel">
            <div class="panel-head"><h2>Gemini · Research &amp; Plan</h2></div>

            @if (_git.IsRepo)
            {
                <div class="git-bar">
                    <span class="tag mono">⎇ @_git.Branch</span>
                    <span class="tag @(_git.Clean ? "" : "warn")">@(_git.Clean ? "clean" : "uncommitted changes")</span>
                    <button class="btn ghost" @onclick="CreateSessionBranch" disabled="@_gitBusy">Branch for this session</button>
                    @if (!_git.Clean)
                    {
                        <button class="btn ghost" @onclick="DiscardChanges" disabled="@_gitBusy">Discard changes</button>
                    }
                    @if (_gitMessage is not null)
                    {
                        <span class="tag subtle">@_gitMessage</span>
                    }
                </div>
            }

            <textarea class="input goal" rows="3" placeholder="Describe the goal for this session…"
                      @bind="_goal"></textarea>
            <div class="row">
                <button class="btn primary" @onclick="GeneratePlan" disabled="@_planning">
                    @(_planning ? "Planning…" : "Generate plan")
                </button>
                @if (!FlowResolver.GetPlanningService(_session!).IsConfigured)
                {
                    <span class="tag warn">GEMINI_API_KEY not set</span>
                }
                @if (_ragSnippetCount > 0)
                {
                    <span class="tag" title="Relevant code injected into the planning context">
                        @_ragSnippetCount code snippet@(_ragSnippetCount == 1 ? "" : "s") injected
                    </span>
                }
            </div>

            <div class="plan-body">
                @if (string.IsNullOrWhiteSpace(_session.PlanningContext))
                {
                    <p class="muted">No plan yet. Set a goal and generate one.</p>
                }
                else
                {
                    <pre class="plan-text">@_session.PlanningContext</pre>
                }
            </div>

            <div class="tasks-section">
                <div class="panel-head">
                    <h2>Test-Driven Tasks</h2>
                    <button class="btn" @onclick="GenerateTasks"
                            disabled="@(_generatingTasks || string.IsNullOrWhiteSpace(_session.PlanningContext))">
                        @(_generatingTasks ? "Generating…" : (_tasks.Count == 0 ? "Generate task list" : "Regenerate"))
                    </button>
                </div>

                @if (_tasks.Count == 0)
                {
                    <p class="muted">Generate a plan, then break it into verifiable tasks.</p>
                }
                else
                {
                    <div class="task-card-list">
                        @foreach (var t in _tasks)
                        {
                            <div class="task-card @(_selectedTask?.Id == t.Id ? "selected" : "") @(t.Risk == RiskLevel.High ? "risk-high-border" : "")"
                                 @onclick="() => SelectTask(t)">
                                <span class="task-dot status-@t.Status.ToString().ToLower()"></span>
                                <div class="task-card-main">
                                    <div class="task-title">
                                        @(t.Sequence + 1). @t.Title
                                        @if (t.Risk != RiskLevel.Low)
                                        {
                                            <span class="badge badge-risk-@t.Risk.ToString().ToLower() ml-2">@t.Risk Risk</span>
                                        }
                                    </div>
                                    <div class="task-sub">
                                        <span class="status status-@t.Status.ToString().ToLower()">@t.Status</span>
                                        @if (!string.IsNullOrWhiteSpace(t.VerificationCommand))
                                        {
                                            <code class="verify-cmd">@t.VerificationCommand</code>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(t.SkillTags))
                                    {
                                        <div class="task-tags">
                                            @foreach (var tag in t.SkillTags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="badge tag">@tag</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_selectedTask is not null)
                {
                    <div class="task-detail">
                        @if (_editingTask)
                        {
                            <label class="field">
                                <span class="field-name">Title</span>
                                <input class="input" @bind="_taskTitleDraft" />
                            </label>
                            <label class="field">
                                <span class="field-name">Description</span>
                                <textarea class="input" rows="3" @bind="_taskDescDraft"></textarea>
                            </label>
                            <label class="field">
                                <span class="field-name">Verification command</span>
                                <textarea class="input mono" rows="2" @bind="_taskVerifyDraft"
                                          placeholder="e.g. dotnet test --filter X (leave blank to skip)"></textarea>
                            </label>
                            <div class="row">
                                <button class="btn primary" @onclick="SaveTaskEdits">Save</button>
                                <button class="btn ghost" @onclick="() => _editingTask = false">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <div class="title-row">
                                <h3>
                                    @_selectedTask.Title
                                    @if (_selectedTask.Risk != RiskLevel.Low)
                                    {
                                        <span class="badge badge-risk-@_selectedTask.Risk.ToString().ToLower() ml-2">@_selectedTask.Risk Risk</span>
                                    }
                                </h3>
                                <button class="btn ghost icon-btn" title="Edit task"
                                        @onclick="StartEditTask" disabled="@_running">✎</button>
                            </div>
                            <p class="muted">@_selectedTask.Description</p>
                            @if (!string.IsNullOrWhiteSpace(_selectedTask.SkillTags))
                            {
                                <div class="task-tags mb-3">
                                    @foreach (var tag in _selectedTask.SkillTags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge tag">@tag</span>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_selectedTask.VerificationCommand))
                            {
                                <div class="verify-line">Verify: <code>@_selectedTask.VerificationCommand</code></div>
                            }
                            <div class="row">
                                <button class="btn primary" @onclick="() => RunTask(_selectedTask)" disabled="@_running">
                                    @(_running ? "Running…" : "Run task")
                                </button>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_selectedTask.VerificationOutput))
                        {
                            <h3>Verification</h3>
                            <pre class="plan-text">@_selectedTask.VerificationOutput</pre>
                            @if (_selectedTask.Status == WorkItemStatus.Failed)
                            {
                                <div class="row gap-2" style="margin-top: 10px;">
                                    <button class="btn warn" @onclick="() => TroubleshootTask(_selectedTask)" disabled="@_troubleshooting">
                                        @(_troubleshooting ? "Asking Gemini…" : "Ask Gemini for a fix")
                                    </button>
                                    <button class="btn primary" @onclick="() => DecomposeAndResolveTask(_selectedTask)" disabled="@_decomposing">
                                        @(_decomposing ? "Decomposing…" : "Decompose & Resolve")
                                    </button>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        <div class="panel console-panel">
            <div class="panel-head">
                <h2>Claude Code · Execution</h2>
                <div class="card-actions">
                    @if (_events.Count > 0)
                    {
                        <button class="btn ghost" @onclick="ClearTranscript" disabled="@_running">Clear</button>
                    }
                    <button class="btn" @onclick="RunFullPlan" disabled="@_running">
                        @(_running ? "Running…" : "Run full plan")
                    </button>
                </div>
            </div>

            <div class="console">
                @foreach (var e in _events)
                {
                    <div class="line line-@e.Kind.ToString().ToLower() @(e.IsError ? "err" : "")">
                        <span class="line-tag">@KindLabel(e.Kind)</span>
                        <span class="line-text">@e.Text</span>
                    </div>
                }
                @if (_events.Count == 0)
                {
                    <div class="muted">Console output will stream here.</div>
                }
            </div>

            @if (_fix is not null)
            {
                <div class="trouble">
                    <div class="trouble-head">
                        ⚠ Gemini fix suggestion@(_fixTask is not null ? $" · {_fixTask.Title}" : "")
                    </div>
                    <pre class="fix-text">@_fix</pre>
                    <div class="row">
                        <button class="btn primary" @onclick="ApplyFix" disabled="@_running">
                            @(_running ? "Applying…" : (_fixTask is not null ? "Apply fix & re-run task" : "Apply fix & re-run"))
                        </button>
                        <button class="btn ghost" @onclick="DismissFix" disabled="@_running">Dismiss</button>
                    </div>
                </div>
            }
            else if (_lastError is not null)
            {
                <div class="trouble">
                    <div class="trouble-head">⚠ Execution error detected</div>
                    <div class="row">
                        <button class="btn warn" @onclick="Troubleshoot" disabled="@_troubleshooting">
                            @(_troubleshooting ? "Asking Gemini…" : "Ask Gemini for a fix")
                        </button>
                        @if (_git.IsRepo && !_git.Clean)
                        {
                            <button class="btn ghost" @onclick="DiscardChanges" disabled="@_gitBusy">Discard changes</button>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <CommitHistory Commits="_recentCommits" />
}

@code {
    [Parameter] public int Id { get; set; }

    private AgentSession? _session;
    private List<SessionTemplate> _templates = new();
    private List<TaskItem> _tasks = new();
    private TaskItem? _selectedTask;
    private bool _editingTask;
    private string _taskTitleDraft = "";
    private string _taskDescDraft = "";
    private string _taskVerifyDraft = "";
    private string _goal = "";
    private bool _planning, _running, _troubleshooting, _generatingTasks, _decomposing;
    private bool _editingName;
    private string _nameDraft = "";
    private int _ragSnippetCount;
    private string? _savedPath;
    private GitStatus _git = new(false, string.Empty, true);
    private bool _gitBusy;
    private string? _gitMessage;
    private IEnumerable<string> _recentCommits = [];
    private readonly List<AgentStreamEvent> _events = new();
    private readonly List<AgentStreamEvent> _pending = new();
    private int? _currentTaskId;
    private string? _activeNodeId;
    private string? _pendingApproval;
    private TaskCompletionSource<bool>? _approvalTcs;
    private ScriptRunMetrics? _metrics;
    private string? _lastError;
    private string? _fix;
    private TaskItem? _fixTask;
    private CancellationTokenSource? _cts;

    // Workspace permission policy applied when running Claude.
    private string _permissionMode = "acceptEdits";
    private IReadOnlyList<string> _allowedTools = Array.Empty<string>();
    private IReadOnlyList<string> _disallowedTools = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _session = await db.Sessions
            .Include(s => s.Tasks)
            .Include(s => s.Template)
            .FirstOrDefaultAsync(s => s.Id == Id);
        _tasks = _session?.Tasks.OrderBy(t => t.Sequence).ToList() ?? new();

        if (_session is not null)
        {
            _templates = await db.SessionTemplates.OrderBy(t => t.Id).ToListAsync();

            var saved = await db.SessionEvents.Where(e => e.AgentSessionId == Id)
                .OrderBy(e => e.Id).ToListAsync();
            _events.AddRange(saved.Select(ToStreamEvent));

            var ws = await db.Workspaces.Include(w => w.CommandRules)
                .FirstOrDefaultAsync(w => w.Id == _session.WorkspaceId);
            if (ws is not null)
            {
                _permissionMode = string.IsNullOrWhiteSpace(ws.PermissionMode) ? "acceptEdits" : ws.PermissionMode;
                (_allowedTools, _disallowedTools) = CommandRulePermissions.Build(ws.CommandRules);
            }

            _git = await Git.GetStatusAsync(_session.RepositoryPath);
            try
            {
                _recentCommits = await Git.GetRecentCommits(_session.RepositoryPath, 5);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error fetching commits: {ex.Message}");
                _recentCommits = [];
            }
        }
    }

    private async Task OnTemplateChanged(ChangeEventArgs e)
    {
        if (_session is null || !int.TryParse(e.Value as string, out var templateId)) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.Sessions.FindAsync(_session.Id);
        if (tracked is null) return;
        tracked.TemplateId = templateId;
        await db.SaveChangesAsync();

        // Mirror onto the in-memory session so the resolver picks the new flow immediately.
        _session.TemplateId = templateId;
        _session.Template = _templates.FirstOrDefault(t => t.Id == templateId);
    }

    private async Task RefreshGit()
    {
        if (_session is not null) _git = await Git.GetStatusAsync(_session.RepositoryPath);
    }

    private async Task CreateSessionBranch()
    {
        if (_session is null || _gitBusy) return;
        _gitBusy = true;
        try
        {
            var result = await Git.CreateBranchAsync(_session.RepositoryPath, $"wheelhouse/session-{_session.Id}");
            _gitMessage = result.Success ? "branch created" : Trim(result.Output);
            await RefreshGit();
        }
        finally { _gitBusy = false; }
    }

    private async Task DiscardChanges()
    {
        if (_session is null || _gitBusy) return;
        _gitBusy = true;
        try
        {
            var result = await Git.DiscardChangesAsync(_session.RepositoryPath);
            _gitMessage = result.Success ? "changes discarded" : Trim(result.Output);
            await RefreshGit();
        }
        finally { _gitBusy = false; }
    }

    private static string Trim(string s) => s.Length > 80 ? s[..80] + "…" : s;

    private enum StageState { Pending, Active, Done }
    private record Stage(string Label, string Sub, StageState State);

    private IEnumerable<Stage> PipelineStages()
    {
        var hasPlan = !string.IsNullOrWhiteSpace(_session?.PlanningContext);
        var hasTasks = _tasks.Count > 0;
        var anyCompleted = _tasks.Any(t => t.Status == WorkItemStatus.Completed);
        var anyVerifying = _tasks.Any(t => t.Status == WorkItemStatus.Verifying);
        var sessionDone = _session?.Status == SessionStatus.Completed;

        yield return new Stage("Plan", "Gemini",
            _planning ? StageState.Active : hasPlan ? StageState.Done : StageState.Pending);
        yield return new Stage("Tasks", "checklist",
            _generatingTasks ? StageState.Active : hasTasks ? StageState.Done : StageState.Pending);
        yield return new Stage("Execute", "Claude",
            _running ? StageState.Active : (anyCompleted || sessionDone) ? StageState.Done : StageState.Pending);
        yield return new Stage("Verify", "tests",
            anyVerifying ? StageState.Active : anyCompleted ? StageState.Done : StageState.Pending);
    }

    private void Emit(AgentStreamEvent e)
    {
        _events.Add(e);
        _pending.Add(e);
        if (e.IsError) _lastError = e.Text;
    }

    private async Task FlushTranscript()
    {
        if (_session is null || _pending.Count == 0) return;
        var batch = _pending.ToList();
        _pending.Clear();

        await using var db = await DbFactory.CreateDbContextAsync();
        foreach (var e in batch)
            db.SessionEvents.Add(new SessionEvent
            {
                AgentSessionId = _session.Id,
                TaskItemId = _currentTaskId,
                Kind = e.Kind.ToString(),
                Text = e.Text,
                ToolName = e.ToolName,
                IsError = e.IsError
            });
        await db.SaveChangesAsync();
    }

    private async Task ClearTranscript()
    {
        if (_session is null || _running) return;
        _events.Clear();
        _pending.Clear();
        _lastError = null;
        _fix = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        await db.SessionEvents.Where(e => e.AgentSessionId == _session.Id).ExecuteDeleteAsync();
    }

    private static AgentStreamEvent ToStreamEvent(SessionEvent s)
        => new(Enum.TryParse<AgentEventKind>(s.Kind, out var k) ? k : AgentEventKind.System,
            s.Text, s.ToolName, s.IsError);

    private void StartRename()
    {
        if (_session is null) return;
        _nameDraft = _session.Name;
        _editingName = true;
    }

    private async Task OnRenameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveName();
        else if (e.Key == "Escape") _editingName = false;
    }

    private async Task SaveName()
    {
        if (_session is null) return;
        var name = _nameDraft.Trim();
        if (name.Length == 0) return;

        _session.Name = name;
        _editingName = false;
        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.Sessions.FindAsync(_session.Id);
        if (tracked is not null) { tracked.Name = name; await db.SaveChangesAsync(); }
    }

    private async Task ExportMarkdown()
    {
        if (_session is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var export = await SessionExport.BuildAsync(db, _session.Id);
        if (export is { } e)
            await JS.InvokeVoidAsync("wheelhouseDownload", e.Filename, e.Markdown);
    }

    private async Task SaveToWorkspace()
    {
        if (_session is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        _savedPath = await SessionExport.SaveToWorkspaceAsync(db, _session.Id, _session.RepositoryPath);
    }

    private async Task GeneratePlan()
    {
        if (_session is null || _planning) return;
        _planning = true;
        try
        {
            // RAG: enrich the planning context with semantically relevant code from the repo.
            var context = await BuildPlanningContext();
            var plan = await FlowResolver.GetPlanningService(_session).GenerateResearchPlanAsync(_goal, context);
            _session.PlanningContext = plan;

            await using var db = await DbFactory.CreateDbContextAsync();
            var tracked = await db.Sessions.FindAsync(_session.Id);
            if (tracked is not null)
            {
                tracked.PlanningContext = plan;
                await db.SaveChangesAsync();
                await StateSync.SyncActiveSessionAsync(_session.Id, _session.RepositoryPath);
            }
        }
        finally { _planning = false; }
    }

    private async Task<string> BuildPlanningContext()
    {
        _ragSnippetCount = 0;
        if (_session is null || string.IsNullOrWhiteSpace(_goal))
            return $"Repository: {_session?.RepositoryPath}";

        string knowledgeContext = "";
        try
        {
            var knowledgePath = Path.Combine(_session.RepositoryPath, ".wheelhouse", "knowledge.md");
            if (File.Exists(knowledgePath))
            {
                var content = await File.ReadAllTextAsync(knowledgePath);
                if (!string.IsNullOrWhiteSpace(content))
                {
                    knowledgeContext = $"## Previous repository knowledge / Lessons learned:\n{content}\n\n";
                }
            }
        }
        catch { /* ignore file read errors */ }

        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var search = scope.ServiceProvider.GetRequiredService<IVectorSearchService>();
            var hits = await search.SearchAsync(_goal, topN: 5, repositoryPath: _session.RepositoryPath);
            _ragSnippetCount = hits.Count;
            return knowledgeContext + RagContext.Build(_session.RepositoryPath, hits);
        }
        catch
        {
            // Repo not indexed / no embedding provider — fall back to a path-only context.
            return knowledgeContext + $"Repository: {_session.RepositoryPath}";
        }
    }

    private async Task GenerateTasks()
    {
        if (_session is null || _generatingTasks || string.IsNullOrWhiteSpace(_session.PlanningContext)) return;
        _generatingTasks = true;
        try
        {
            var generated = await FlowResolver.GetPlanningService(_session).GenerateTasksAsync(_session.PlanningContext);

            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = db.Tasks.Where(t => t.AgentSessionId == _session.Id);
            db.Tasks.RemoveRange(existing);

            var seq = 0;
            foreach (var t in generated)
            {
                db.Tasks.Add(new TaskItem
                {
                    AgentSessionId = _session.Id,
                    Sequence = seq++,
                    Title = t.Title,
                    Description = t.Description,
                    VerificationCommand = t.VerificationCommand,
                    Status = WorkItemStatus.Pending
                });
            }
            await db.SaveChangesAsync();
            await LoadTasks();
            _selectedTask = _tasks.FirstOrDefault();
            await StateSync.SyncActiveSessionAsync(_session.Id, _session.RepositoryPath);
        }
        finally { _generatingTasks = false; }
    }

    private async Task LoadTasks()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _tasks = await db.Tasks.Where(t => t.AgentSessionId == _session!.Id)
            .OrderBy(t => t.Sequence).ToListAsync();
    }

    private void SelectTask(TaskItem t)
    {
        _selectedTask = t;
        _editingTask = false;
        _fix = null;
    }

    private void StartEditTask()
    {
        if (_selectedTask is null) return;
        _taskTitleDraft = _selectedTask.Title;
        _taskDescDraft = _selectedTask.Description;
        _taskVerifyDraft = _selectedTask.VerificationCommand ?? "";
        _editingTask = true;
    }

    private async Task SaveTaskEdits()
    {
        if (_selectedTask is null) return;
        var title = _taskTitleDraft.Trim();
        if (title.Length == 0) return;

        _selectedTask.Title = title;
        _selectedTask.Description = _taskDescDraft.Trim();
        _selectedTask.VerificationCommand = string.IsNullOrWhiteSpace(_taskVerifyDraft) ? null : _taskVerifyDraft.Trim();
        _editingTask = false;

        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.Tasks.FindAsync(_selectedTask.Id);
        if (tracked is not null)
        {
            tracked.Title = _selectedTask.Title;
            tracked.Description = _selectedTask.Description;
            tracked.VerificationCommand = _selectedTask.VerificationCommand;
            await db.SaveChangesAsync();
        }
    }

    // The session runs a visual node graph when its template carries one.
    private bool HasGraph => !string.IsNullOrWhiteSpace(_session?.Template?.GraphJson);

    private async Task RunGraph()
    {
        if (_session is null || _running) return;
        _running = true;
        _lastError = null;
        _fix = null;
        _activeNodeId = null;
        _currentTaskId = null;
        _metrics = null;
        _cts = new CancellationTokenSource();
        ScriptExecutor.ApprovalHandler = RequestApproval;
        await SetSessionStatus(SessionStatus.Running);
        try
        {
            _metrics = await ScriptExecutor.RunGraphAsync(_session, GraphLog, GraphNodeActive, _cts.Token);
            await SetSessionStatus(_lastError is null ? SessionStatus.Completed : SessionStatus.Failed);
        }
        catch (Exception ex)
        {
            Emit(new AgentStreamEvent(AgentEventKind.Error, ex.Message, IsError: true));
            await SetSessionStatus(SessionStatus.Failed);
        }
        finally
        {
            ScriptExecutor.ApprovalHandler = null;
            _pendingApproval = null;
            _running = false;
            _activeNodeId = null;
            await FlushTranscript();
            await LoadTasks(); // a generate-tasks node may have populated the list
            await InvokeAsync(StateHasChanged);
        }
    }

    // Human-in-the-loop gate: a wait-approval node calls this and blocks on the returned task
    // until the user clicks Approve/Reject.
    private Task<bool> RequestApproval(string message)
    {
        _approvalTcs = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);
        _pendingApproval = message;
        _ = InvokeAsync(StateHasChanged);
        return _approvalTcs.Task;
    }

    private void ResolveApproval(bool approved)
    {
        _pendingApproval = null;
        _approvalTcs?.TrySetResult(approved);
    }

    // Parallel branches call these from background threads, so marshal the shared-state mutation
    // onto the circuit's dispatcher to keep _events/_activeNodeId access serialized with rendering.
    private void GraphLog(string text, AgentEventKind kind)
        => _ = InvokeAsync(() =>
        {
            Emit(new AgentStreamEvent(kind, text, IsError: kind == AgentEventKind.Error));
            StateHasChanged();
        });

    private void GraphNodeActive(string nodeId)
        => _ = InvokeAsync(() =>
        {
            _activeNodeId = nodeId;
            StateHasChanged();
        });

    private Task RunFullPlan() => RunPlan(null);

    private async Task RunPlan(string? fixContext)
    {
        if (_session is null || _running) return;
        _selectedTask = null;
        _currentTaskId = null;
        var prompt = string.IsNullOrWhiteSpace(_session.PlanningContext)
            ? (string.IsNullOrWhiteSpace(_goal) ? "Summarize this repository." : _goal)
            : $"Execute this plan step by step:\n\n{_session.PlanningContext}";
        if (!string.IsNullOrWhiteSpace(fixContext))
            prompt += $"\n\nA previous attempt failed. Apply the following diagnosis and fix:\n{fixContext}";

        await SetSessionStatus(SessionStatus.Running);
        var err = await StreamRun(prompt);
        await SetSessionStatus(err is null ? SessionStatus.Completed : SessionStatus.Failed);
        await FlushTranscript();
    }

    // Feeds a Gemini fix suggestion back into the failed task (or full plan) and re-runs it.
    private async Task ApplyFix()
    {
        if (_session is null || _running || string.IsNullOrWhiteSpace(_fix)) return;
        var fix = _fix;
        var task = _fixTask;
        _fix = null;
        _fixTask = null;
        if (task is not null) await RunTask(task, fix);
        else await RunPlan(fix);
    }

    private void DismissFix()
    {
        _fix = null;
        _fixTask = null;
    }

    private async Task RunTask(TaskItem task, string? fixContext = null)
    {
        if (_session is null || _running) return;
        _selectedTask = task;
        _currentTaskId = task.Id;
        _fix = null;
        try
        {
            await SetTaskStatus(task, WorkItemStatus.InProgress);

            var prompt =
                $"Implement the following task in this repository. Make the necessary code changes.\n\n" +
                $"Task: {task.Title}\n\n{task.Description}";
            if (!string.IsNullOrWhiteSpace(fixContext))
                prompt += $"\n\nA previous attempt failed verification. Apply the following diagnosis and " +
                          $"fix, then complete the task:\n{fixContext}";
            if (!string.IsNullOrWhiteSpace(_session.PlanningContext))
                prompt += $"\n\nOverall plan for context:\n{_session.PlanningContext}";

            var err = await StreamRun(prompt);
            if (err is not null)
            {
                await SetTaskStatus(task, WorkItemStatus.Failed);
                return;
            }

            if (string.IsNullOrWhiteSpace(task.VerificationCommand))
            {
                await SetTaskStatus(task, WorkItemStatus.Completed);
                return;
            }

            // Test-Driven Handoff: the task isn't done until its verification command passes.
            await SetTaskStatus(task, WorkItemStatus.Verifying);
            Emit(new AgentStreamEvent(AgentEventKind.System, $"Verifying: {task.VerificationCommand}"));
            await InvokeAsync(StateHasChanged);

            var (exitCode, output) = await FlowResolver.GetOrchestrationService(_session).RunVerificationAsync(
                task.VerificationCommand, _session.RepositoryPath);
            var passed = exitCode == 0;
            task.VerificationOutput = $"$ {task.VerificationCommand}\n(exit {exitCode})\n\n{output}";
            
            if (passed && task.Risk == RiskLevel.High)
            {
                task.Status = WorkItemStatus.AwaitingApproval;
                await SaveTask(task);
                Emit(new AgentStreamEvent(AgentEventKind.System, $"Verification passed. Awaiting human approval for High-Risk task: {task.Title}"));
                await InvokeAsync(StateHasChanged);

                var approved = await RequestApproval($"High-Risk Task '{task.Title}' passed verification. Do you approve the changes?");
                
                task.Status = approved ? WorkItemStatus.Completed : WorkItemStatus.Failed;
                if (approved) task.CompletedAt = DateTime.UtcNow;
                passed = approved;
            }
            else
            {
                task.Status = passed ? WorkItemStatus.Completed : WorkItemStatus.Failed;
                if (passed) task.CompletedAt = DateTime.UtcNow;
            }
            await SaveTask(task);

            Emit(new AgentStreamEvent(
                passed ? AgentEventKind.Result : AgentEventKind.Error,
                passed ? "Verification passed." : $"Verification failed (exit {exitCode}).",
                IsError: !passed));
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            await FlushTranscript();
            _currentTaskId = null;
        }
    }

    private async Task<string?> StreamRun(string prompt)
    {
        _running = true;
        _lastError = null;
        _fix = null;
        _cts = new CancellationTokenSource();
        try
        {
            var request = new AgentRunRequest(
                prompt, _session!.RepositoryPath,
                PermissionMode: _permissionMode,
                AllowedTools: _allowedTools.Count > 0 ? _allowedTools : null,
                DisallowedTools: _disallowedTools.Count > 0 ? _disallowedTools : null);
            await foreach (var evt in FlowResolver.GetOrchestrationService(_session).RunAsync(request, _cts.Token))
            {
                Emit(evt);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Emit(new AgentStreamEvent(AgentEventKind.Error, ex.Message, IsError: true));
        }
        finally { _running = false; }
        return _lastError;
    }

    private async Task Troubleshoot()
    {
        if (_session is null || _lastError is null || _troubleshooting) return;
        _troubleshooting = true;
        try
        {
            var recent = string.Join("\n", _events.TakeLast(20).Select(e => e.Text));
            _fix = await FlowResolver.GetPlanningService(_session).TroubleshootAsync("claude run", recent, _session.RepositoryPath);
            _fixTask = null; // fix targets the full-plan run, not a specific task
        }
        finally { _troubleshooting = false; }
    }

    private async Task TroubleshootTask(TaskItem task)
    {
        if (_session is null || _troubleshooting) return;
        _troubleshooting = true;
        try
        {
            _fix = await FlowResolver.GetPlanningService(_session).TroubleshootAsync(
                task.VerificationCommand ?? task.Title,
                task.VerificationOutput ?? "(no output)",
                _session.RepositoryPath);
            _fixTask = task; // fix targets this task so it can be re-run
        }
        finally { _troubleshooting = false; }
    }

    private async Task SetTaskStatus(TaskItem task, WorkItemStatus status)
    {
        task.Status = status;
        if (status == WorkItemStatus.Completed) task.CompletedAt = DateTime.UtcNow;
        await SaveTask(task);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveTask(TaskItem task)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.Tasks.FindAsync(task.Id);
        if (tracked is null) return;
        tracked.Status = task.Status;
        tracked.VerificationOutput = task.VerificationOutput;
        tracked.CompletedAt = task.CompletedAt;
        await db.SaveChangesAsync();
        await StateSync.SyncActiveSessionAsync(_session!.Id, _session.RepositoryPath);
    }

    private async Task SetSessionStatus(SessionStatus status)
    {
        if (_session is null) return;
        _session.Status = status;
        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.Sessions.FindAsync(_session.Id);
        if (tracked is not null)
        {
            tracked.Status = status;
            if (status is SessionStatus.Completed or SessionStatus.Failed)
                tracked.CompletedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();
            await StateSync.SyncActiveSessionAsync(_session.Id, _session.RepositoryPath);

            if (status == SessionStatus.Completed)
            {
                // Trigger compounding lessons learned loop in background
                _ = Task.Run(async () => await RunLessonsLearnedLoop());
            }
        }
    }

    private async Task RunLessonsLearnedLoop()
    {
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var db = scope.ServiceProvider.GetRequiredService<WheelHouseDbContext>();
            var gemini = scope.ServiceProvider.GetRequiredService<IGeminiService>();
            
            var session = await db.Sessions.FindAsync(_session!.Id);
            if (session is null) return;
            
            var tasks = await db.Tasks.Where(t => t.AgentSessionId == session.Id)
                .OrderBy(t => t.Sequence).ToListAsync();

            var tasksSummary = new System.Text.StringBuilder();
            foreach (var t in tasks)
            {
                tasksSummary.AppendLine($"- Task: {t.Title}");
                tasksSummary.AppendLine($"  Status: {t.Status}");
                if (!string.IsNullOrWhiteSpace(t.VerificationOutput))
                {
                    tasksSummary.AppendLine($"  Verification Output:\n{t.VerificationOutput}");
                }
            }

            var existingKnowledge = "";
            var knowledgeDir = Path.Combine(session.RepositoryPath, ".wheelhouse");
            var knowledgePath = Path.Combine(knowledgeDir, "knowledge.md");
            if (File.Exists(knowledgePath))
            {
                existingKnowledge = await File.ReadAllTextAsync(knowledgePath);
            }

            var prompt = 
                $"You are the planning brain of WheelHouse. A coding session has just completed successfully.\n\n" +
                $"Goal: {_goal}\n\n" +
                $"Original Plan:\n{session.PlanningContext}\n\n" +
                $"Executed Tasks:\n{tasksSummary}\n\n";

            if (!string.IsNullOrWhiteSpace(existingKnowledge))
            {
                prompt += $"Existing Knowledge/Lessons Learned in this repository:\n{existingKnowledge}\n\n" +
                          $"Synthesize a consolidated, updated version of 'Lessons Learned' about this codebase, merging the existing knowledge with new learnings from this session.\n";
            }
            else
            {
                prompt += $"Synthesize a short, durable markdown summary of 'Lessons Learned' about this codebase for future runs.\n";
            }

            prompt += 
                $"Focus on architectural patterns used, specific gotchas, database schema details, API design, or config requirements discovered.\n" +
                $"Keep it concise and actionable for another AI agent entering this repo.\n" +
                $"Do not output any conversational introduction or conclusion. Return ONLY the markdown contents.";

            var reply = await gemini.CompleteAsync(prompt);
            if (!string.IsNullOrWhiteSpace(reply) && !reply.Contains("request failed") && !reply.Contains("not configured"))
            {
                Directory.CreateDirectory(knowledgeDir);
                await File.WriteAllTextAsync(knowledgePath, reply, System.Text.Encoding.UTF8);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error running lessons learned loop: " + ex.Message);
        }
    }

    private async Task DecomposeAndResolveTask(TaskItem task)
    {
        if (_session is null || _decomposing) return;
        _decomposing = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var gemini = scope.ServiceProvider.GetRequiredService<IGeminiService>();

            var prompt =
                $"You are the planning brain of WheelHouse. A task has failed verification.\n\n" +
                $"Failed Task: {task.Title}\n" +
                $"Description: {task.Description}\n" +
                $"Verification Command: `{task.VerificationCommand}`\n\n" +
                $"## Verification Output:\n```\n{task.VerificationOutput}\n```\n\n" +
                $"## Repository context:\n{_session.RepositoryPath}\n\n" +
                $"Decompose this failure into a sequence of small, concrete corrective tasks to isolate and fix the problem.\n" +
                $"Each task must be actionable by a downstream coding agent (Claude Code).\n" +
                $"Each item must be exactly: {{\"title\":string,\"description\":string,\"verificationCommand\":string|null,\"risk\":string,\"skillTags\":string[]}}.\n\n" +
                $"Rules for risk:\n" +
                $"- Must be exactly one of: \"Low\", \"Medium\", or \"High\". Assess the risk based on the potential impact of changes.\n\n" +
                $"Rules for skillTags:\n" +
                $"- A JSON array of string tags representing the technologies, tools, or patterns involved.\n\n" +
                $"Rules for verificationCommand:\n" +
                $"- Must exit 0 on success, non-zero on failure from repository root.\n" +
                $"- Use build/test commands to prove the sub-task works (e.g. `dotnet build`, `dotnet test`).\n\n" +
                $"Return ONLY the JSON array of sub-tasks.";

            var reply = await gemini.CompleteAsync(prompt);
            var subTasks = ParseSubTasks(reply);
            if (subTasks.Count == 0) return;

            await using var db = await DbFactory.CreateDbContextAsync();
            var subsequentTasks = await db.Tasks
                .Where(t => t.AgentSessionId == _session.Id && t.Sequence > task.Sequence)
                .ToListAsync();

            foreach (var t in subsequentTasks)
            {
                t.Sequence += subTasks.Count;
            }

            var nextSeq = task.Sequence + 1;
            foreach (var st in subTasks)
            {
                st.AgentSessionId = _session.Id;
                st.Sequence = nextSeq++;
                db.Tasks.Add(st);
            }

            await db.SaveChangesAsync();
            await LoadTasks();
            await StateSync.SyncActiveSessionAsync(_session.Id, _session.RepositoryPath);
            
            _selectedTask = _tasks.FirstOrDefault(t => t.Sequence == task.Sequence + 1);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error decomposing task: " + ex.Message);
        }
        finally
        {
            _decomposing = false;
        }
    }

    private IReadOnlyList<TaskItem> ParseSubTasks(string raw)
    {
        var start = raw.IndexOf('[');
        var end = raw.LastIndexOf(']');
        if (start < 0 || end <= start) return Array.Empty<TaskItem>();
        var json = raw.Substring(start, end - start + 1);

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var list = new List<TaskItem>();
            foreach (var el in doc.RootElement.EnumerateArray())
            {
                var riskStr = el.TryGetProperty("risk", out var r) ? r.GetString() : null;
                var risk = Enum.TryParse<RiskLevel>(riskStr, true, out var parsedRisk) ? parsedRisk : RiskLevel.Low;

                string? skillTags = null;
                if (el.TryGetProperty("skillTags", out var s) && s.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    var tags = new List<string>();
                    foreach (var tagEl in s.EnumerateArray())
                    {
                        var tag = tagEl.GetString();
                        if (!string.IsNullOrWhiteSpace(tag)) tags.Add(tag.Trim().ToLowerInvariant());
                    }
                    if (tags.Count > 0) skillTags = string.Join(",", tags);
                }

                list.Add(new TaskItem
                {
                    Title = el.TryGetProperty("title", out var t) ? t.GetString() ?? "" : "",
                    Description = el.TryGetProperty("description", out var d) ? d.GetString() ?? "" : "",
                    VerificationCommand = el.TryGetProperty("verificationCommand", out var v) &&
                                          v.ValueKind == System.Text.Json.JsonValueKind.String
                        ? v.GetString()
                        : null,
                    Risk = risk,
                    SkillTags = skillTags,
                    Status = WorkItemStatus.Pending
                });
            }
            return list;
        }
        catch { return Array.Empty<TaskItem>(); }
    }

    private static string KindLabel(AgentEventKind k) => k switch
    {
        AgentEventKind.AssistantText => "claude",
        AgentEventKind.ToolUse => "tool",
        AgentEventKind.ToolResult => "result",
        AgentEventKind.System => "sys",
        AgentEventKind.Result => "done",
        AgentEventKind.Error => "error",
        _ => "·"
    };

    public void Dispose()
    {
        _approvalTcs?.TrySetResult(false); // unblock a waiting approval node on teardown
        _cts?.Cancel();
    }
}
